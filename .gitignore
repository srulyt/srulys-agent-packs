# ===========================================
# Agent Pack STM Directories
# ===========================================

# Factory STM (root level)
/.factory/
/.copilot-factory/
/.prompts/
/.local/

# ===========================================
# Installed Factory Files (created by init.cmd)
# ===========================================

# Roo Agent Factory (installed to root)
/.roo/
/.roomodes

# Copilot Factory (installed to root - all .github subdirectories)
/.github/agents/
/.github/instructions/
/.github/prompts/
/.github/skills/

# Pack STM directories under agent-packs/
# Pattern: .{pack-name}-stm/ or any *-stm/ directory
agent-packs/**/*-stm/

# SaaS Design Studio - Short-Term Memory
# Generated files, workflow state, and component output
agent-packs/**/.design-studio/

# Customer Sentiment Analysis - Memory
# Sentiment analysis session data and workflow state
agent-packs/**/.sentiment-memory/

# Product Feedback Gatherer - STM and LTM
# Feedback gathering session data and trend history
agent-packs/**/.feedback-stm/
agent-packs/**/.feedback-ltm/

# Ralph Copilot CLI - STM (testing)
# Note: Ralph STM is typically created in user projects, not under agent-packs/
agent-packs/**/.ralph-stm/

# Copilot Factory - Session state
# Factory workflow sessions and generated artifacts
agent-packs/**/.copilot-factory/

# Roo Factory - Session state (for generated/installed packs)
agent-packs/**/.factory/

agent-packs/product-brief/.context/

# ===========================================
# IDE & System Files
# ===========================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ===========================================
# Dependencies (if any)
# ===========================================
node_modules/

# ===========================================
# Eval framework working directories
# Engine code in eval_engine/ is committed.
# Per-repo evals live in evals/; runtime subdirs are gitignored:
# ===========================================
evals/packs/*/workspaces/
evals/packs/*/results-local/
evals/packs/*/reports/
evals/data/
__pycache__/
*.pyc
.pytest_cache/

